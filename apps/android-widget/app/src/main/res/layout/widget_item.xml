<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/provider_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:letterSpacing="0.1"
        android:text="CLAUDE"
        android:textColor="#BB86FC"
        android:textSize="9sp"
        android:textStyle="bold" />

    <!-- Row Primary (5h) -->
    <LinearLayout
        android:id="@+id/primary_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/primary_label"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text="5h"
            android:textColor="#66FFFFFF"
            android:textSize="9sp" />

        <ProgressBar
            android:id="@+id/usage_bar_primary"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <TextView
            android:id="@+id/usage_text_primary"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0%"
            android:textColor="#03DAC6"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Row Secondary (W) -->
    <LinearLayout
        android:id="@+id/secondary_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/secondary_label"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text="W"
            android:textColor="#66FFFFFF"
            android:textSize="9sp" />

        <ProgressBar
            android:id="@+id/usage_bar_secondary"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:progressDrawable="@drawable/custom_progress_bar" />

        <TextView
            android:id="@+id/usage_text_secondary"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0%"
            android:textColor="#03DAC6"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
